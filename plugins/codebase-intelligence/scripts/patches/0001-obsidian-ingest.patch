+# Machine-local overrides for settings.toml.
+# Copy this file to settings.local.toml (git-ignored) and edit as needed.
+# Only the keys you specify here are overridden; everything else comes from settings.toml.
+#
+# Use case: run all-MiniLM-L6-v2 from a local path instead of downloading from HuggingFace.
+#   1. Download the model once:
+#        python -c "from sentence_transformers import SentenceTransformer; SentenceTransformer('all-MiniLM-L6-v2')"
+#      Model lands in ~/.cache/huggingface/hub/models--sentence-transformers--all-MiniLM-L6-v2/
+#      Or copy/symlink it anywhere you like.
+#   2. Set the path below:
+
+[embedding]
+embedding_model = "/absolute/path/to/all-MiniLM-L6-v2"
+
+# Other common per-machine overrides:
+#
+# [structuring]
+# provider = "ollama"
+# model    = "qwen2.5:14b"
+# ollama_base_url = "http://localhost:11434"
